NODE_ENV=production
PORT=10000
APP_BASE_URL=https://votre-app.onrender.com
PUBLIC_SITE_NAME=Mon école

# PostgreSQL (Render PostgreSQL ou autre)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# PayTech
PAYTECH_API_KEY=remplacer_par_votre_api_key
PAYTECH_API_SECRET=remplacer_par_votre_api_secret
PAYTECH_ENV=test
PAYTECH_TARGET_PAYMENT=

# Thinkific
THINKIFIC_API_KEY=remplacer_par_votre_thinkific_api_key
THINKIFIC_SUBDOMAIN=mon-ecole
THINKIFIC_SEND_WELCOME_EMAIL=true

# URLs de retour
SUCCESS_REDIRECT_URL=https://mon-ecole.thinkific.com/pages/merci
CANCEL_REDIRECT_URL=https://mon-ecole.thinkific.com/pages/paiement-annule

# Optionnel: webhook privé si vous voulez notifier un autre système
POST_PAYMENT_WEBHOOK_URL=
